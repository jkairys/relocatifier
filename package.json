{
  "name": "relocatifier",
  "private": true,
  "description": "Root tooling for deploy/data tasks — pins wrangler and worker types. The app lives in app/.",
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "~5.8.3",
    "wrangler": "^4.20.0"
  }
}
